<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <SolidColorBrush x:Key="FieldBackgroundBrush" Color="#0A0C08" />
        <SolidColorBrush x:Key="FieldPanelBrush" Color="#171B12" />
        <SolidColorBrush x:Key="FieldPanelAltBrush" Color="#1D2318" />
        <SolidColorBrush x:Key="FieldCardBrush" Color="#20271A" />
        <SolidColorBrush x:Key="FieldChromeBrush" Color="#242C1D" />
        <SolidColorBrush x:Key="FieldLineBrush" Color="#50583C" />
        <SolidColorBrush x:Key="FieldStrongLineBrush" Color="#7B845B" />
        <SolidColorBrush x:Key="FieldTextBrush" Color="#D6D1B6" />
        <SolidColorBrush x:Key="FieldMutedBrush" Color="#98A07C" />
        <SolidColorBrush x:Key="FieldOliveBrush" Color="#7E8D58" />
        <SolidColorBrush x:Key="FieldTanBrush" Color="#A59262" />
        <SolidColorBrush x:Key="FieldBrownBrush" Color="#5E4832" />
        <SolidColorBrush x:Key="FieldRedBrush" Color="#9A4F40" />
        <SolidColorBrush x:Key="FieldAmberBrush" Color="#C19A52" />
        <SolidColorBrush x:Key="FieldBlackBrush" Color="#050605" />
    </Styles.Resources>

    <Style Selector="Window">
        <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource FieldTextBrush}" />
        <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Courier New" />
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FieldTextBrush}" />
    </Style>

    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{StaticResource FieldMutedBrush}" />
    </Style>

    <Style Selector="TextBlock.panelTitle">
        <Setter Property="Foreground" Value="{StaticResource FieldTanBrush}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.panelSubtitle">
        <Setter Property="Foreground" Value="{StaticResource FieldMutedBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.stencil">
        <Setter Property="Foreground" Value="{StaticResource FieldOliveBrush}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{StaticResource FieldPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FieldLineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Border.panelAlt">
        <Setter Property="Background" Value="{StaticResource FieldPanelAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FieldLineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Border.card">
        <Setter Property="Background" Value="{StaticResource FieldCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FieldLineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Border.commandBar">
        <Setter Property="Background" Value="{StaticResource FieldChromeBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FieldStrongLineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Border.badge">
        <Setter Property="Background" Value="{StaticResource FieldBlackBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FieldStrongLineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <Style Selector="Button.commandButton">
        <Setter Property="Background" Value="{StaticResource FieldOliveBrush}" />
        <Setter Property="Foreground" Value="{StaticResource FieldBlackBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FieldTanBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="TextBox.fieldInput">
        <Setter Property="Background" Value="{StaticResource FieldBlackBrush}" />
        <Setter Property="Foreground" Value="{StaticResource FieldTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FieldLineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>
</Styles>
